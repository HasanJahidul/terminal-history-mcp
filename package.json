{
  "name": "terminal-history-mcp",
  "version": "0.2.0",
  "description": "Search your shell history (zsh/bash/fish) via MCP. SQLite FTS5, local, private, secret-redacted.",
  "type": "module",
  "bin": {
    "terminal-history-mcp": "dist/cli.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "!dist/test",
    "!dist/**/*.test.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "logo.png",
    "logo.svg"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "index": "node dist/cli-index.js",
    "test": "node --test dist/test/*.test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "terminal",
    "shell",
    "history",
    "zsh",
    "bash",
    "fish",
    "search",
    "fts5",
    "sqlite",
    "claude"
  ],
  "author": "Jahidul Hasan <contact@hasanjahidul.com>",
  "license": "MIT",
  "homepage": "https://github.com/hasanjahidul/terminal-history-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hasanjahidul/terminal-history-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/hasanjahidul/terminal-history-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^11.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
